# ---------------------------------------------------------------------------
# Variaveis de ambiente do Backend — Adaptive Training AI
# Copie este arquivo para .env e preencha com suas credenciais.
# ---------------------------------------------------------------------------

# Supabase — Credenciais do projeto cloud
# Encontre no Dashboard do Supabase > Settings > API
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_KEY=eyJ...sua_service_role_key_aqui

# Ollama — Configuracao do servico de IA local (usado a partir da Fase 3)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Geral
DEBUG=true
